APP_DOMAIN=blueprint.example.com
APP_PROTOCOL=https
APP_IMAGE=ghcr.io/your-account/blueprint:2026-03-23-01

RAILS_ENV=production
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5
RAILS_MASTER_KEY=replace_with_contents_of_config_master_key
SECRET_KEY_BASE=replace_with_a_long_random_secret
RAILS_ASSUME_SSL=true
RAILS_FORCE_SSL=true
ACTIVE_JOB_QUEUE_ADAPTER=sidekiq

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=blueprint_production
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=replace_with_postgres_password

REDIS_URL=redis://redis:6379/1

ACTIVE_STORAGE_SERVICE=minio
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=replace_with_minio_password
AWS_REGION=us-east-1
AWS_BUCKET=blueprint-production
AWS_ENDPOINT=http://minio:9000
AWS_FORCE_PATH_STYLE=true

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace_with_minio_password

SIDEKIQ_USERNAME=admin
SIDEKIQ_PASSWORD=replace_with_sidekiq_basic_auth_password

GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token
