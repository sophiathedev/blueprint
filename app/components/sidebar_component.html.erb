<aside
  class="sidebar-shell flex w-full shrink-0 flex-col border-b border-black/10 bg-white md:fixed md:inset-y-0 md:left-0 md:z-20 md:h-screen md:w-[296px] md:overflow-y-auto md:border-r md:border-b-0 md:overscroll-contain"
  data-sidebar-layout-target="sidebar"
>
  <div class="border-b border-black/10 px-3 py-3">
    <div class="flex items-center justify-between gap-3">
      <div class="sidebar-brand flex min-w-0 items-center gap-3">
        <div class="relative flex h-11 w-11 items-center justify-center rounded-2xl border border-primary-200 bg-primary-50">
          <div class="relative h-6 w-6">
            <span class="absolute inset-x-0 top-0 h-[2px] rounded-full bg-primary-300"></span>
            <span class="absolute inset-y-0 left-0 w-[2px] rounded-full bg-primary-300"></span>
            <span class="absolute bottom-0 right-0 h-4 w-4 rounded-[5px] border-2 border-primary-500 bg-white"></span>
            <span class="absolute left-[3px] top-[3px] h-2.5 w-2.5 rounded-[4px] bg-primary-500"></span>
          </div>
          <span class="absolute -right-1 -top-1 h-2.5 w-2.5 rounded-full bg-primary-500"></span>
        </div>

        <div class="sidebar-wordmark min-w-0">
          <div class="space-y-0.5 leading-none">
            <p class="truncate text-[16px] font-black uppercase tracking-wider text-black">BLUE</p>
            <p class="truncate text-[16px] font-black uppercase tracking-wider text-primary-600">PRINT</p>
          </div>
        </div>
      </div>

      <%= render ButtonComponent.new(
        label: 'Collapse sidebar',
        type: :icon,
        icon: 'panel-left-close',
        class: 'shrink-0 self-center',
        data: { action: 'click->sidebar-layout#toggle' }
      ) %>
    </div>
  </div>

  <div class="flex-1 px-2 py-2">
    <nav class="space-y-1">
      <% items.each do |item| %>
        <% active = item[:active] %>
        <%= link_to item[:href], class: [
          "sidebar-nav-link flex items-center gap-2 rounded-2xl border px-1.5 py-1.5 transition-colors",
          active ? "border-primary-500 bg-primary-500 text-white" : "border-transparent bg-stone-50 text-black hover:border-black/10 hover:bg-stone-100"
        ] do %>
          <span class="<%= [
            "sidebar-item-icon flex h-7.5 w-7.5 shrink-0 items-center justify-center rounded-[14px] text-[10px] font-semibold uppercase tracking-[0.16em]",
            active ? "bg-white/14 text-white" : "bg-white text-black/70"
          ].join(' ') %>">
            <%= helpers.lucide_icon(item[:icon], class: 'h-4 w-4', "aria-hidden": true) %>
          </span>

          <span class="sidebar-item-copy flex min-w-0 flex-1 items-center justify-between gap-2">
            <span class="sidebar-item-label truncate text-sm font-medium"><%= item[:label] %></span>

            <% if item[:badge].present? %>
              <span class="<%= [
                "sidebar-item-badge rounded-full px-1.5 py-0.5 text-[10px] font-semibold",
                active ? "bg-white/14 text-white" : "bg-black/5 text-black/65"
              ].join(' ') %>">
                <%= item[:badge] %>
              </span>
            <% end %>
          </span>
        <% end %>
      <% end %>
    </nav>
  </div>

  <div class="border-t border-black/10 px-2 py-2">
    <div class="sidebar-auth-buttons grid gap-2">
      <%= render ButtonComponent.new(
        label: 'Đăng nhập',
        type: :navigate,
        variant: :primary,
        href: '#',
        icon: 'log-in',
        full_width: true,
        class: 'sidebar-auth-button'
      ) %>
    </div>
  </div>
</aside>
