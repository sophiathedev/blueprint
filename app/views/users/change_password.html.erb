<% content_for :title, "Blueprint | Đổi mật khẩu" %>

<main class="mx-auto flex min-h-screen w-full max-w-xl items-center justify-center px-4 py-10 sm:px-6">
  <section class="w-full">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary-600">Đổi mật khẩu</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-black">Thiết lập mật khẩu mới</h2>
      <p class="mt-3 text-sm leading-6 text-black/60">
        Đây là lần đăng nhập đầu tiên, vui lòng đổi mật khẩu trước khi tiếp tục vào hệ thống.
      </p>
    </div>

    <%= form_with url: change_password_path, method: :patch, scope: :user, class: 'mt-8 space-y-5' do |form| %>
      <%= render InputFieldComponent.new(
        form: form,
        field: :password,
        label: 'Mật khẩu mới',
        type: :password,
        required: true,
        autocomplete: 'new-password',
        value: @password
      ) %>

      <%= render InputFieldComponent.new(
        form: form,
        field: :password_confirmation,
        label: 'Nhập lại mật khẩu mới',
        type: :password,
        required: true,
        autocomplete: 'new-password',
        value: @password_confirmation
      ) %>

      <div class="pt-2">
        <%= render ButtonComponent.new(
          label: 'Cập nhật mật khẩu',
          type: :submit,
          variant: :primary,
          icon: 'key-round',
          full_width: true
        ) %>
      </div>
    <% end %>
  </section>
</main>
