<% content_for :title, "Blueprint | Đăng nhập" %>

<main class="mx-auto flex min-h-screen w-full max-w-xl items-center justify-center px-4 py-10 sm:px-6">
  <section class="w-full">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary-600">Đăng nhập</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-black">Chào mừng bạn quay lại</h2>
      <p class="mt-3 text-sm leading-6 text-black/60">
        Nhập email và mật khẩu để truy cập không gian làm việc của bạn.
      </p>
    </div>

    <%= form_with url: login_path, scope: :user, class: 'mt-8 space-y-5' do |form| %>
      <%= render InputFieldComponent.new(
        form: form,
        field: :email,
        label: 'Email',
        type: :email,
        value: @email,
        autocomplete: 'email',
        autofocus: true,
        required: true
      ) %>

      <%= render InputFieldComponent.new(
        form: form,
        field: :password,
        label: 'Mật khẩu',
        type: :password,
        autocomplete: 'current-password',
        required: true
      ) %>

      <div class="pt-2">
        <%= render ButtonComponent.new(
          label: 'Đăng nhập',
          type: :submit,
          variant: :primary,
          icon: 'log-in',
          full_width: true
        ) %>
      </div>
    <% end %>
  </section>
</main>
