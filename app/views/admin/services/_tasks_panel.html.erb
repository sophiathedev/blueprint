<%= turbo_frame_tag "service_#{service.id}_tasks_panel" do %>
  <% show_all_tasks = local_assigns.fetch(:show_all_tasks, false) %>
  <% visible_tasks = show_all_tasks ? tasks : tasks.first(5) %>
  <% remaining_tasks_count = tasks.size - visible_tasks.size %>

  <% if tasks.any? %>
    <div class="pl-4 pr-2 py-2">
      <div class="border-l-2 border-stone-300 pl-6">
        <% visible_tasks.each_with_index do |task, index| %>
          <% current_task = edit_task&.id == task.id ? edit_task : task %>

          <div
            class="<%= ['relative border-black/10 py-1.5', index.zero? ? nil : 'border-t'].compact.join(' ') %>"
            data-controller="modal"
            data-modal-open-value="<%= edit_task&.id == task.id %>"
          >
            <span class="absolute -left-[35px] top-1/2 inline-flex h-5 w-5 -translate-y-1/2 items-center justify-center rounded-full bg-stone-300 text-[10px] font-semibold text-white"><%= index + 1 %></span>

            <div class="grid grid-cols-[minmax(0,1.2fr)_minmax(140px,0.8fr)_44px] items-center gap-3 pr-2">
              <div class="min-w-0">
                <p class="truncate text-[13px] font-medium text-black/85"><%= task.name %></p>
              </div>

              <div class="min-w-0">
                <p class="truncate text-[13px] text-black/60">
                  PIC: <span class="font-medium text-black/80"><%= task.member&.display_name || 'Chưa có PIC' %></span>
                </p>
              </div>

              <div class="flex items-center justify-end overflow-visible">
                <%= render DropdownComponent.new(
                  items: [
                    { label: 'Chỉnh sửa', button: true, icon: 'pencil', data: { action: 'click->modal#open click->dropdown#close' } },
                    { label: 'Xóa', href: admin_partner_service_task_path(partner, service, task), method: :delete, icon: 'trash-2', tone: :danger, confirm_label: 'Xác nhận xóa?', confirm_icon: 'check', data: { turbo_frame: "service_#{service.id}_tasks_panel" } }
                  ],
                  direction: :bottom_right
                ) do |dropdown| %>
                  <% dropdown.with_trigger do %>
                    <button
                      type="button"
                      class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-transparent text-black/45 transition hover:bg-stone-200 hover:text-black"
                      aria-label="Mở thao tác task"
                    >
                      <%= lucide_icon('ellipsis', class: 'h-3.5 w-3.5', "aria-hidden": true) %>
                    </button>
                  <% end %>
                <% end %>
              </div>
            </div>

            <%= render ModalComponent.new(
              title: ("Cập nhật task ".html_safe + content_tag(:span, task.name, class: 'text-primary-600')),
              open: edit_task&.id == task.id
            ) do |modal| %>
              <% modal.with_body do %>
                <%= render 'admin/tasks/form',
                  partner: partner,
                  service: service,
                  task: current_task,
                  member_options: member_options,
                  submit_label: 'Lưu thay đổi',
                  submit_icon: 'save',
                  form_data: { turbo_frame: "service_#{service.id}_tasks_panel" } %>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <% if remaining_tasks_count.positive? %>
          <div class="relative border-t border-black/10 py-2">
            <div class="flex items-center justify-between gap-3 rounded-2xl bg-white/70 px-3 py-2 text-[13px] text-black/55">
              <span>Còn <span class="font-semibold text-black/75"><%= remaining_tasks_count %></span> task nữa</span>
              <%= link_to tasks_panel_admin_partner_service_path(partner, service, show_all: true),
                class: 'inline-flex items-center gap-2 rounded-full bg-stone-200 px-3 py-1 text-[12px] font-semibold text-black transition hover:bg-stone-300',
                data: { turbo_frame: "service_#{service.id}_tasks_panel" } do %>
                <span>Xem tất cả</span>
                <%= lucide_icon('arrow-right', class: 'h-3.5 w-3.5', "aria-hidden": true) %>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if show_all_tasks && tasks.size > 5 %>
          <div class="border-t border-black/10 py-2">
            <div class="flex justify-end">
              <%= link_to tasks_panel_admin_partner_service_path(partner, service),
                class: 'inline-flex items-center gap-2 rounded-full bg-stone-200 px-3 py-1 text-[12px] font-semibold text-black transition hover:bg-stone-300',
                data: { turbo_frame: "service_#{service.id}_tasks_panel" } do %>
                <%= lucide_icon('chevron-up', class: 'h-3.5 w-3.5', "aria-hidden": true) %>
                <span>Thu gọn</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="border-l-2 border-dashed border-stone-300 pl-6 py-2.5 text-[13px] text-black/50">
      Chưa có task nào.
    </div>
  <% end %>
<% end %>
