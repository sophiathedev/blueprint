<section id="admin_tasks_page" data-controller="search-form modal" data-search-form-mode-value="server" data-modal-open-value="<%= @open_task_modal.present? %>">
  <div class="rounded-[28px] border border-black/10 bg-white p-5 md:p-6">
    <div class="flex flex-col gap-4 border-b border-black/10 pb-5 md:flex-row md:items-end md:justify-between">
      <div class="flex items-center gap-3">
        <%= link_to admin_partner_services_path(@partner),
          class: 'inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-stone-200 bg-stone-100 text-black transition-colors hover:border-stone-300 hover:bg-stone-200 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:ring-offset-2',
          aria: { label: 'Quay lại danh sách gói dịch vụ' } do %>
          <%= lucide_icon('arrow-left', class: 'h-4 w-4', "aria-hidden": true) %>
        <% end %>

        <h1 class="text-3xl font-semibold tracking-tight text-black">
          Task của <span class="text-primary-600">
            <%= @service.name %> (<%= link_to @partner.name, admin_partner_services_path(@partner), class: 'underline-offset-4 hover:underline' %>)
          </span>
        </h1>
      </div>

      <div class="flex w-full flex-col gap-3 md:w-auto md:flex-row md:items-center">
        <div class="relative w-full md:w-[280px]" data-controller="clearable-input">
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-black/35">
            <%= lucide_icon('search', class: 'h-4 w-4', "aria-hidden": true) %>
          </span>
          <input
            type="text"
            name="q"
            value="<%= @query %>"
            placeholder="Tìm theo tên task"
            class="w-full rounded-2xl border border-stone-200 bg-stone-50 py-2 pl-10 pr-10 text-sm text-black outline-none transition focus:border-primary-400 focus:bg-white focus:ring-4 focus:ring-primary-100"
            data-search-form-target="input"
            data-clearable-input-target="input"
            data-action="input->search-form#submitWithDebounce input->clearable-input#sync"
          >
          <button
            type="button"
            class="absolute inset-y-0 right-0 hidden items-center pr-3 text-black/35 transition hover:text-black"
            data-clearable-input-target="clear"
            data-action="click->clearable-input#clear"
            aria-label="Xóa nội dung"
          >
            <%= lucide_icon('x', class: 'h-4 w-4', "aria-hidden": true) %>
          </button>
        </div>

        <button
          type="button"
          class="inline-flex items-center justify-center gap-2 rounded-2xl border border-primary-500 bg-primary-500 px-3 py-2 text-sm font-semibold text-white transition-colors hover:border-primary-600 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:ring-offset-2"
          data-action="click->modal#open"
        >
          <%= lucide_icon('plus', class: 'h-4 w-4 shrink-0', "aria-hidden": true) %>
          <span>Thêm task</span>
        </button>
      </div>
    </div>

    <% if @tasks.any? %>
      <div class="mt-5 overflow-visible" data-search-form-target="table">
        <div class="overflow-hidden rounded-t-[24px] border border-black/10 border-b-0">
          <div class="grid grid-cols-[56px_minmax(0,1fr)_minmax(180px,0.8fr)_44px] items-center gap-3 bg-stone-50 px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-black/45">
            <span class="text-center">STT</span>
            <span>Tên task</span>
            <span>PIC</span>
            <span class="text-right"></span>
          </div>
        </div>

        <div class="overflow-visible rounded-b-[24px] border border-black/10 bg-white">
          <% @tasks.each_with_index do |task, index| %>
            <div
              class="<%= [
                'grid grid-cols-[56px_minmax(0,1fr)_minmax(180px,0.8fr)_44px] items-center gap-3 px-3 py-2.5',
                index.zero? ? nil : 'border-t border-black/10'
              ].compact.join(' ') %>"
              data-search-form-target="row"
              data-search-text="<%= [task.name, task.member&.display_name].compact.join(' ') %>"
            >
              <div class="text-sm text-center font-medium text-black/55"><%= index + 1 %></div>

              <div class="flex min-w-0 items-center">
                <div id="task-display-<%= task.id %>" class="flex min-w-0 items-center gap-2">
                  <span class="truncate text-sm font-semibold text-black"><%= task.name %></span>
                  <button
                    type="button"
                    class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-stone-100 text-black/55 transition hover:bg-stone-200 hover:text-black"
                    onclick="document.getElementById('task-display-<%= task.id %>')?.classList.add('hidden'); document.getElementById('task-edit-<%= task.id %>')?.classList.remove('hidden'); const input = document.getElementById('task-input-<%= task.id %>'); input?.focus(); input?.select();"
                    aria-label="Sửa tên task"
                  >
                    <%= lucide_icon('pencil', class: 'h-3.5 w-3.5', "aria-hidden": true) %>
                  </button>
                </div>

                <div id="task-edit-<%= task.id %>" class="hidden w-full">
                  <%= form_with model: [:admin, @partner, @service, task], class: 'w-full' do |form| %>
                    <%= hidden_field_tag :q, @query %>
                    <div class="relative" data-controller="clearable-input">
                      <%= form.text_field :name,
                        id: "task-input-#{task.id}",
                        value: task.name,
                        class: 'w-full rounded-2xl border border-stone-200 bg-white px-3 py-2 pr-10 text-sm font-medium text-black outline-none transition focus:border-primary-400 focus:ring-4 focus:ring-primary-100',
                        onblur: 'this.form.requestSubmit()',
                        onkeydown: "if (event.key === 'Enter') { event.preventDefault(); this.form.requestSubmit(); } if (event.key === 'Escape') { event.preventDefault(); this.value = this.defaultValue; this.form.closest(\"#task-edit-#{task.id}\")?.classList.add(\"hidden\"); document.getElementById(\"task-display-#{task.id}\")?.classList.remove(\"hidden\"); }",
                        data: { clearable_input_target: 'input', action: 'input->clearable-input#sync' } %>
                      <button
                        type="button"
                        class="absolute inset-y-0 right-0 hidden items-center pr-3 text-black/35 transition hover:text-black"
                        data-clearable-input-target="clear"
                        data-action="click->clearable-input#clear"
                        aria-label="Xóa nội dung"
                      >
                        <%= lucide_icon('x', class: 'h-4 w-4', "aria-hidden": true) %>
                      </button>
                    </div>
                  <% end %>
                </div>
              </div>

              <div class="min-w-0">
                <%= form_with model: [:admin, @partner, @service, task], class: 'w-full' do |form| %>
                  <%= hidden_field_tag :q, @query %>
                  <%= render SelectFieldComponent.new(
                    form: form,
                    field: :member_id,
                    label: 'PIC',
                    choices: @inline_member_options,
                    selected: task.member_id,
                    selected_label: task.member&.display_name,
                    prompt: 'Chọn PIC',
                    searchable: true,
                    search_placeholder: 'Tìm member...',
                    submit_on_choose: true,
                    show_label: false,
                    full_width: false,
                    trigger_icon: 'user-round',
                    trigger_icon_only_when_selected: true,
                    selected_trigger_class: '!border-primary-200 !bg-primary-50 !text-primary-700 hover:!border-primary-300 hover:!bg-primary-100',
                    unselected_trigger_class: '!border-dashed !border-stone-300 !bg-white !text-black/55 hover:!border-stone-400 hover:!bg-stone-50 hover:!text-black',
                    class: [
                      'min-w-[170px] max-w-full rounded-full px-3 py-1.5 shadow-none'
                    ].join(' ')
                  ) %>
                <% end %>
              </div>

              <div class="flex items-center justify-end overflow-visible">
                <%= render DropdownComponent.new(
                  items: [
                    { label: 'Xóa task', href: admin_partner_service_task_path(@partner, @service, task), method: :delete, icon: 'trash-2', tone: :danger, confirm_label: 'Xác nhận xóa?', confirm_icon: 'check' }
                  ],
                  direction: :bottom_right
                ) do |dropdown| %>
                  <% dropdown.with_trigger do %>
                    <button
                      type="button"
                      class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-black/55 ring-1 ring-black/10 transition hover:bg-stone-100 hover:text-black"
                      aria-label="Mở thao tác task"
                    >
                      <%= lucide_icon('ellipsis', class: 'h-4 w-4', "aria-hidden": true) %>
                    </button>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="mt-5 hidden rounded-[24px] border border-dashed border-black/15 bg-stone-50 px-5 py-10 text-center" data-search-form-target="noResults">
        <h2 class="text-lg font-semibold text-black">Không tìm thấy task phù hợp</h2>
        <p class="mt-2 text-sm leading-6 text-black/55">
          Thử nhập lại tên task với từ khóa khác.
        </p>
      </div>
    <% else %>
      <div class="mt-5 rounded-[24px] border border-dashed border-black/15 bg-stone-50 px-5 py-10 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-primary-600 shadow-sm ring-1 ring-black/5">
          <%= lucide_icon('list-todo', class: 'h-6 w-6', "aria-hidden": true) %>
        </div>
        <h2 class="mt-4 text-xl font-semibold text-black">Chưa có task nào</h2>
        <p class="mt-2 text-sm leading-6 text-black/55">
          Tạo task đầu tiên cho service này để bắt đầu quản lý.
        </p>
        <div class="mt-5">
          <button
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-2xl border border-primary-500 bg-primary-500 px-3 py-2 text-sm font-semibold text-white transition-colors hover:border-primary-600 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:ring-offset-2"
            data-action="click->modal#open"
          >
            <%= lucide_icon('plus', class: 'h-4 w-4 shrink-0', "aria-hidden": true) %>
            <span>Tạo task đầu tiên</span>
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <%= render ModalComponent.new(
    title: "Tạo task cho #{@service.name}",
    description: 'Bạn có thể chọn PIC ngay lúc tạo hoặc gán lại sau trực tiếp trên bảng task.',
    open: @open_task_modal.present?
  ) do |modal| %>
    <% modal.with_body do %>
      <%= render 'form', partner: @partner, service: @service, task: @task %>
    <% end %>
  <% end %>
</section>
