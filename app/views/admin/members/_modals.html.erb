<div id="members_modals">
  <%= render ModalComponent.new(
    title: 'Tạo người dùng mới',
    description: 'Nhập tên và email. Hệ thống sẽ tự động sinh mật khẩu mạnh sau khi tạo tài khoản.',
    open: @open_create_modal.present?
  ) do |modal| %>
    <% modal.with_body do %>
      <%= render 'form',
        member: @new_member,
        submit_label: 'Tạo người dùng',
        password_note: 'Mật khẩu sẽ được hệ thống sinh tự động và hiển thị một lần sau khi tạo thành công.' %>
    <% end %>
  <% end %>

  <% if @edit_member.present? %>
    <div data-controller="modal" data-modal-open-value="<%= @open_edit_member_id.present? %>">
      <%= render ModalComponent.new(
        title: 'Cập nhật người dùng',
        description: 'Chỉnh sửa tên và email của tài khoản member.',
        open: @open_edit_member_id.present?
      ) do |modal| %>
        <% modal.with_body do %>
          <%= render 'form', member: @edit_member, submit_label: 'Lưu thay đổi' %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @password_member.present? %>
    <div data-controller="modal" data-modal-open-value="<%= @open_reset_password_member_id.present? %>">
      <%= render ModalComponent.new(
        title: 'Thay đổi mật khẩu',
        description: "Nhập mật khẩu mới cho #{@password_member.name.presence || @password_member.email} và xác nhận lại để hoàn tất thay đổi.",
        open: @open_reset_password_member_id.present?
      ) do |modal| %>
        <% modal.with_body do %>
          <%= form_with url: reset_password_admin_member_path(@password_member), method: :patch, model: @password_member, class: 'space-y-4', data: { controller: 'modal-form', action: 'submit->modal-form#handleSubmit turbo:before-fetch-response->modal-form#beforeFetchResponse turbo:submit-end->modal-form#submitEnd' } do |form| %>
            <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-900">
              Sau khi lưu, mật khẩu cũ sẽ không còn sử dụng được nữa.
            </div>

            <%= render InputFieldComponent.new(
              form: form,
              field: :password,
              label: 'Mật khẩu mới',
              type: :password,
              placeholder: 'Nhập mật khẩu mới',
              autofocus: true,
              onkeydown: "if (event.key === 'Enter') { event.preventDefault(); this.form?.requestSubmit(); }",
              data: { autofocus_modal: true }
            ) %>

            <%= render InputFieldComponent.new(
              form: form,
              field: :password_confirmation,
              label: 'Xác nhận mật khẩu mới',
              type: :password,
              placeholder: 'Nhập lại mật khẩu mới'
            ) %>

            <div class="flex items-center justify-end gap-2">
              <%= link_to admin_members_path,
                class: 'inline-flex items-center justify-center gap-2 rounded-2xl border border-stone-200 bg-stone-100 px-3 py-2 text-sm font-semibold text-black transition-colors hover:border-stone-300 hover:bg-stone-200' do %>
                Hủy
              <% end %>

              <div>
                <%= render ButtonComponent.new(
                  label: 'Lưu mật khẩu mới',
                  type: :submit,
                  variant: :primary,
                  icon: 'save'
                ) %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @credentials_modal.present? %>
    <div data-controller="modal" data-modal-open-value="true">
      <%= render ModalComponent.new(
        title: @credentials_modal[:title],
        description: @credentials_modal[:description],
        open: true
      ) do |modal| %>
        <% modal.with_body do %>
          <%= render 'credentials_modal', credentials: @credentials_modal %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
