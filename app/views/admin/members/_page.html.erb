<% content_for :title, 'Blueprint | Thành viên' %>

<section
  id="admin_members_page"
  class="space-y-4"
  data-controller="admin-members-page search-form"
  data-admin-members-page-base-url-value="<%= admin_members_path %>"
  data-search-form-mode-value="server"
  data-search-form-delay-value="500"
>
  <div data-controller="modal" data-modal-open-value="<%= @open_create_modal.present? %>">
    <div class="rounded-[28px] border border-black/10 bg-white p-5 md:p-6">
      <div class="flex flex-col gap-4 border-b border-black/10 pb-5 md:flex-row md:items-end md:justify-between">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-black">Quản lý thành viên</h1>
        </div>

        <div class="flex w-full flex-col gap-3 md:w-auto md:flex-row md:items-center">
          <div class="relative w-full md:w-[320px]" data-controller="clearable-input">
            <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-black/35">
              <%= lucide_icon('search', class: 'h-4 w-4', "aria-hidden": true) %>
            </span>
            <input
              type="text"
              name="q"
              value="<%= params[:q].to_s %>"
              placeholder="Tìm theo tên hoặc email"
              class="w-full rounded-2xl border border-stone-200 bg-stone-50 py-2 pl-10 pr-10 text-sm text-black outline-none transition focus:border-primary-400 focus:bg-white focus:ring-4 focus:ring-primary-100"
              data-search-form-target="input"
              data-clearable-input-target="input"
              data-action="input->search-form#submitWithDebounce input->clearable-input#sync"
            >
            <button
              type="button"
              class="absolute inset-y-0 right-0 hidden items-center pr-3 text-black/35 transition hover:text-black"
              data-clearable-input-target="clear"
              data-action="click->clearable-input#clear"
              aria-label="Xóa nội dung"
            >
              <%= lucide_icon('x', class: 'h-4 w-4', "aria-hidden": true) %>
            </button>
          </div>

          <button
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-2xl border border-primary-500 bg-primary-500 px-3 py-2 text-sm font-semibold text-white transition-colors hover:border-primary-600 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:ring-offset-2"
            data-action="click->modal#open"
          >
            <%= lucide_icon('user-plus', class: 'h-4 w-4 shrink-0', "aria-hidden": true) %>
            <span>Thêm người dùng</span>
          </button>
        </div>
      </div>

      <% if @members.any? %>
        <div class="mt-5 overflow-visible" data-search-form-target="table">
          <div class="overflow-x-auto md:overflow-visible">
            <div class="min-w-[980px] overflow-visible">
              <div class="overflow-hidden rounded-t-[24px] border border-black/10 border-b-0">
                <div class="grid grid-cols-[72px_minmax(0,1fr)_minmax(140px,0.7fr)_minmax(0,1.15fr)_minmax(180px,0.95fr)_56px] items-center gap-3 bg-stone-50 px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-black/45">
                  <span class="text-center">STT</span>
                  <span>Tên</span>
                  <span>Roles</span>
                  <span>Email</span>
                  <span>Đăng nhập lần cuối</span>
                  <span class="text-right">Action</span>
                </div>
              </div>

              <div class="overflow-visible rounded-b-[24px] border border-black/10 bg-white">
                <% @members.each_with_index do |member, index| %>
                  <div
                    class="<%= ['grid grid-cols-[72px_minmax(0,1fr)_minmax(140px,0.7fr)_minmax(0,1.15fr)_minmax(180px,0.95fr)_56px] items-center gap-3 px-4 py-3', index.zero? ? nil : 'border-t border-black/10'].compact.join(' ') %>"
                    data-search-form-target="row"
                    data-search-text="<%= [member.name.presence, member.email].compact.join(' ') %>"
                  >
                    <div class="text-center text-sm font-medium text-black/55"><%= index + 1 %></div>
                    <div class="min-w-0">
                      <p class="truncate text-sm font-semibold text-black">
                        <%= member.name.presence || '-' %>
                        <% if member == current_user %>
                          <span class="ml-2 rounded-full bg-primary-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.14em] text-primary-700">Bạn</span>
                        <% end %>
                      </p>
                    </div>
                    <div class="min-w-0">
                      <span class="<%= [
                        'inline-flex rounded-full px-2.5 py-1 text-xs font-semibold',
                        member.admin? ? 'bg-primary-50 text-primary-700' : 'bg-stone-100 text-black/70'
                      ].join(' ') %>">
                        <%= member.role_label %>
                      </span>
                    </div>
                    <div class="min-w-0">
                      <p class="truncate text-sm text-black/70"><%= member.email %></p>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm text-black/70"><%= member.last_login_label %></p>
                    </div>
                    <div class="flex items-center justify-end overflow-visible">
                      <% dropdown_items = [
                        { label: 'Sửa người dùng', href: admin_members_path(edit_member_id: member.id), icon: 'pencil' },
                        { label: 'Thay đổi mật khẩu', href: admin_members_path(reset_password_member_id: member.id), icon: 'key-round' }
                      ] %>
                      <% unless member == current_user %>
                        <% dropdown_items << { label: 'Xóa người dùng', href: admin_member_path(member), method: :delete, icon: 'trash-2', tone: :danger, confirm_label: 'Xác nhận xóa?', confirm_icon: 'check' } %>
                      <% end %>

                      <%= render DropdownComponent.new(
                        items: dropdown_items,
                        direction: :bottom_right
                      ) do |dropdown| %>
                        <% dropdown.with_trigger do %>
                          <button
                            type="button"
                            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-black/55 ring-1 ring-black/10 transition hover:bg-stone-100 hover:text-black"
                            aria-label="Mở thao tác người dùng"
                          >
                            <%= lucide_icon('ellipsis', class: 'h-4 w-4', "aria-hidden": true) %>
                          </button>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-5 hidden rounded-[24px] border border-dashed border-black/15 bg-stone-50 px-5 py-10 text-center" data-search-form-target="noResults">
          <h2 class="text-lg font-semibold text-black">Không tìm thấy người dùng phù hợp</h2>
          <p class="mt-2 text-sm leading-6 text-black/55">
            Thử tìm lại theo tên hoặc email với từ khóa khác.
          </p>
        </div>
      <% else %>
        <div class="mt-5 rounded-[24px] border border-dashed border-black/15 bg-stone-50 px-5 py-10 text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-primary-600 shadow-sm ring-1 ring-black/5">
            <%= lucide_icon('users-round', class: 'h-6 w-6', "aria-hidden": true) %>
          </div>
          <h2 class="mt-4 text-xl font-semibold text-black">Chưa có thành viên nào</h2>
          <p class="mt-2 text-sm leading-6 text-black/55">
            Tạo tài khoản member đầu tiên để bắt đầu quản lý người dùng trong khu vực admin.
          </p>
          <div class="mt-5">
            <button
              type="button"
              class="inline-flex items-center justify-center gap-2 rounded-2xl border border-primary-500 bg-primary-500 px-3 py-2 text-sm font-semibold text-white transition-colors hover:border-primary-600 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:ring-offset-2"
              data-action="click->modal#open"
            >
              <%= lucide_icon('user-plus', class: 'h-4 w-4 shrink-0', "aria-hidden": true) %>
              <span>Tạo người dùng đầu tiên</span>
            </button>
          </div>
        </div>
      <% end %>
    </div>

    <%= render ModalComponent.new(
      title: 'Tạo người dùng mới',
      description: 'Nhập tên và email. Hệ thống sẽ tự động sinh mật khẩu mạnh sau khi tạo tài khoản.',
      open: @open_create_modal.present?
    ) do |modal| %>
      <% modal.with_body do %>
        <%= render 'form',
          member: @new_member,
          submit_label: 'Tạo người dùng',
          password_note: 'Mật khẩu sẽ được hệ thống sinh tự động và hiển thị một lần sau khi tạo thành công.' %>
      <% end %>
    <% end %>
  </div>

  <% if @edit_member.present? %>
    <div data-controller="modal" data-modal-open-value="<%= @open_edit_member_id.present? %>">
      <%= render ModalComponent.new(
        title: 'Cập nhật người dùng',
        description: 'Chỉnh sửa tên và email của tài khoản member.',
        open: @open_edit_member_id.present?
      ) do |modal| %>
        <% modal.with_body do %>
          <%= render 'form', member: @edit_member, submit_label: 'Lưu thay đổi' %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @password_member.present? %>
    <div data-controller="modal" data-modal-open-value="<%= @open_reset_password_member_id.present? %>">
      <%= render ModalComponent.new(
        title: 'Thay đổi mật khẩu',
        description: "Nhập mật khẩu mới cho #{@password_member.name.presence || @password_member.email} và xác nhận lại để hoàn tất thay đổi.",
        open: @open_reset_password_member_id.present?
      ) do |modal| %>
        <% modal.with_body do %>
          <%= form_with url: reset_password_admin_member_path(@password_member), method: :patch, model: @password_member, class: 'space-y-4' do |form| %>
            <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-900">
              Sau khi lưu, mật khẩu cũ sẽ không còn sử dụng được nữa.
            </div>

            <%= render InputFieldComponent.new(
              form: form,
              field: :password,
              label: 'Mật khẩu mới',
              type: :password,
              placeholder: 'Nhập mật khẩu mới',
              autofocus: true,
              data: { autofocus_modal: true }
            ) %>

            <%= render InputFieldComponent.new(
              form: form,
              field: :password_confirmation,
              label: 'Xác nhận mật khẩu mới',
              type: :password,
              placeholder: 'Nhập lại mật khẩu mới'
            ) %>

            <div class="flex items-center justify-end gap-2">
              <%= link_to admin_members_path,
                class: 'inline-flex items-center justify-center gap-2 rounded-2xl border border-stone-200 bg-stone-100 px-3 py-2 text-sm font-semibold text-black transition-colors hover:border-stone-300 hover:bg-stone-200' do %>
                Hủy
              <% end %>

              <div>
                <%= render ButtonComponent.new(
                  label: 'Lưu mật khẩu mới',
                  type: :submit,
                  variant: :primary,
                  icon: 'save'
                ) %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @credentials_modal.present? %>
    <div data-controller="modal" data-modal-open-value="true">
      <%= render ModalComponent.new(
        title: @credentials_modal[:title],
        description: @credentials_modal[:description],
        open: true
      ) do |modal| %>
        <% modal.with_body do %>
          <%= render 'credentials_modal', credentials: @credentials_modal %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
