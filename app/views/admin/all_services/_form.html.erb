<%= form_with model: service, url: admin_services_path, class: 'space-y-4', data: { controller: 'modal-form', action: 'submit->modal-form#handleSubmit turbo:before-fetch-response->modal-form#beforeFetchResponse turbo:submit-end->modal-form#submitEnd' } do |form| %>
  <%= render SelectFieldComponent.new(
    form: form,
    field: :partner_id,
    label: 'Đối tác',
    choices: partner_options.reject { |_label, value| value.blank? },
    selected: service.partner_id,
    prompt: 'Chọn đối tác',
    searchable: true,
    search_placeholder: 'Tìm đối tác...'
  ) %>

  <%= render InputFieldComponent.new(
    form: form,
    field: :name,
    label: 'Tên dịch vụ',
    placeholder: 'Nhập tên dịch vụ',
    autofocus: true,
    onkeydown: "if (event.key === 'Enter') { event.preventDefault(); this.form?.requestSubmit(); }",
    data: { autofocus_modal: true }
  ) %>

  <div class="flex items-center justify-end gap-2">
    <button
      type="button"
      class="inline-flex items-center justify-center gap-2 rounded-2xl border border-stone-200 bg-stone-100 px-3 py-2 text-sm font-semibold text-black transition-colors hover:border-stone-300 hover:bg-stone-200"
      data-action="modal#close"
    >
      Hủy
    </button>

    <%= render ButtonComponent.new(
      label: 'Tạo dịch vụ',
      type: :submit,
      variant: :primary,
      icon: 'plus'
    ) %>
  </div>
<% end %>
