<% content_for :title, 'Blueprint | Settings' %>
<% progress_radius = 7 %>
<% progress_circumference = 2 * Math::PI * progress_radius %>
<% progress_offset = progress_circumference - (@setting.google_sheets_sync_progress_ratio * progress_circumference) %>
<% syncing_now = @setting.google_sheets_last_sync_status == 'syncing' %>

<section id="admin_settings_page" class="space-y-4">
  <div class="rounded-[28px] border border-black/10 bg-white p-5 md:p-6">
    <div class="mb-5 border-b border-black/10 pb-5">
      <h1 class="text-3xl font-semibold tracking-tight text-black">Settings hệ thống</h1>
    </div>

    <%= form_with model: @setting, url: admin_settings_path, method: :patch, class: 'space-y-5' do |form| %>
      <%= render InputFieldComponent.new(
        form: form,
        field: :telegram_api_key,
        label: 'Telegram API key',
        placeholder: 'Nhập Telegram API key',
        autocomplete: 'off',
        spellcheck: false
      ) %>
      <p class="text-sm leading-6 text-black/55">
        Sau khi lưu token, hệ thống sẽ tự gọi webhook Telegram về domain hiện tại của app nếu domain đó truy cập công khai.
        Nếu bạn đang dùng `localhost`, hãy dùng domain public như môi trường deploy thật hoặc tunnel để Telegram gọi webhook vào được.
      </p>

      <div class="flex items-center justify-end">
        <%= render ButtonComponent.new(
          label: 'Lưu thay đổi',
          type: :submit,
          variant: :primary,
          icon: 'save'
        ) %>
      </div>
    <% end %>
  </div>

  <div
    class="rounded-[28px] border border-black/10 bg-white p-5 md:p-6"
    data-controller="google-sheets-sync-status"
    data-google-sheets-sync-status-url-value="<%= admin_settings_google_sheets_sync_status_path %>"
  >
    <div class="mb-5 flex flex-wrap items-center justify-between gap-3 border-b border-black/10 pb-5">
      <h2 class="text-2xl font-semibold tracking-tight text-black">Google Sheets Backup</h2>

      <div class="flex flex-wrap items-center gap-3">
        <%= form_with url: admin_settings_cancel_google_sheets_sync_path, method: :post, class: [@setting.google_sheets_cancellable? ? nil : 'hidden', 'contents'].compact.join(' '), data: { google_sheets_sync_status_target: 'cancelButton' } do %>
          <%= render ButtonComponent.new(
            label: 'Hủy sync',
            type: :submit,
            variant: :secondary,
            icon: 'x',
            class: '!border !border-dashed !border-rose-600 !bg-white !text-rose-600 hover:!border-rose-700 hover:!bg-rose-50 hover:!text-rose-700'
          ) %>
        <% end %>

        <%= form_with url: admin_settings_sync_google_sheets_path, method: :post, class: 'contents' do %>
          <%= hidden_field_tag :sync_mode, 'full' %>
          <%= render ButtonComponent.new(
            label: 'Sync lại toàn bộ',
            type: :submit,
            variant: :secondary,
            icon: 'database',
            class: '!border !border-dashed !border-primary-600 !bg-white !text-primary-600 hover:!border-primary-700 hover:!bg-primary-50 hover:!text-primary-700'
          ) %>
        <% end %>

        <%= form_with url: admin_settings_sync_google_sheets_path, method: :post, class: 'contents' do %>
          <%= hidden_field_tag :sync_mode, 'manual' %>
          <%= render ButtonComponent.new(
            label: 'Sync ngay',
            type: :submit,
            variant: :primary,
            icon: 'refresh-cw'
          ) %>
        <% end %>
      </div>
    </div>

    <%= form_with model: @setting, url: admin_settings_path, method: :patch, class: 'space-y-5' do |form| %>
      <div>
        <div class="flex w-full items-center justify-between gap-4 rounded-[24px] border border-stone-200 bg-white px-4 py-3 transition hover:border-stone-300">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold text-black">Bật đồng bộ Google Sheets</p>
            <p class="mt-1 text-xs leading-5 text-black/55">Khi bật, hệ thống sẽ tự đồng bộ theo chu kỳ bạn cấu hình bên dưới.</p>
          </div>

          <div class="ml-auto shrink-0">
            <%= form.check_box :google_sheets_enabled,
              class: 'peer sr-only',
              id: 'app_setting_google_sheets_enabled' %>
            <label
              for="app_setting_google_sheets_enabled"
              class="block cursor-pointer peer-disabled:cursor-not-allowed peer-disabled:opacity-70 peer-checked:[&_.toggle-track]:bg-primary-500 peer-disabled:[&_.toggle-track]:bg-stone-200/80 peer-checked:[&_.toggle-thumb]:translate-x-5"
            >
              <span class="toggle-track flex h-7 w-12 items-center rounded-full bg-stone-200 p-1 transition">
                <span class="toggle-thumb h-5 w-5 rounded-full bg-white shadow-sm transition-transform"></span>
              </span>
            </label>
          </div>
        </div>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <div class="space-y-2">
          <%= form.label :google_sheets_spreadsheet_id, 'Spreadsheet link', class: 'text-sm font-semibold text-black/80' %>

          <div class="flex overflow-hidden rounded-2xl border border-stone-200 bg-stone-50 transition focus-within:border-primary-400 focus-within:bg-white focus-within:ring-4 focus-within:ring-primary-100">
            <input
              type="text"
              value="<%= @setting.google_sheets_spreadsheet_link.presence || 'Chưa có link. Hãy bấm Sync ngay để hệ thống tự tạo.' %>"
              readonly
              class="min-w-0 flex-1 border-0 bg-transparent px-4 py-2 text-sm text-black outline-none focus:ring-0"
              data-google-sheets-sync-status-target="spreadsheetLinkInput"
            >

            <%= link_to (@setting.google_sheets_spreadsheet_link.presence || '#'),
              target: '_blank',
              rel: 'noopener noreferrer',
              aria: (@setting.google_sheets_spreadsheet_link.present? ? {} : { disabled: true }),
              tabindex: (@setting.google_sheets_spreadsheet_link.present? ? nil : -1),
              class: [
                'inline-flex w-[110px] shrink-0 items-center justify-center gap-2 border-l border-stone-200 bg-white px-4 py-2 text-sm font-semibold transition-colors',
                (@setting.google_sheets_spreadsheet_link.present? ? 'text-black hover:bg-stone-100' : 'pointer-events-none text-black/45')
              ].join(' '),
              data: { google_sheets_sync_status_target: 'spreadsheetLinkAction' } do %>
              <%= lucide_icon('external-link', class: 'h-4 w-4', "aria-hidden": true) %>
              Mở
            <% end %>
          </div>
        </div>

        <div class="space-y-2">
          <%= form.label :google_sheets_sync_interval_value, 'Chu kỳ sync', class: 'text-sm font-semibold text-black/80' %>

          <div class="flex overflow-hidden rounded-2xl border border-stone-200 bg-stone-50 transition focus-within:border-primary-400 focus-within:bg-white focus-within:ring-4 focus-within:ring-primary-100">
            <%= form.number_field :google_sheets_sync_interval_value,
              value: @setting.google_sheets_sync_interval_value,
              min: 1,
              placeholder: 'Ví dụ: 5',
              class: 'min-w-0 flex-1 border-0 bg-transparent px-4 py-2 text-sm text-black outline-none focus:ring-0' %>

            <div class="w-px self-stretch bg-stone-200"></div>

            <div class="relative w-[110px] shrink-0">
              <%= form.select :google_sheets_sync_interval_unit,
                options_for_select([
                  ['Phút', 'minutes'],
                  ['Giờ', 'hours'],
                  ['Ngày', 'days']
                ], @setting.google_sheets_sync_interval_unit.to_s),
                { prompt: 'Chọn đơn vị' },
                class: 'h-full w-full appearance-none border-0 bg-transparent px-4 py-2 pr-10 text-sm text-black outline-none focus:ring-0' %>

              <span class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-black/35">
                <%= lucide_icon('chevrons-up-down', class: 'h-4 w-4', "aria-hidden": true) %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-[24px] border border-black/10 bg-stone-50 p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-black/40">Trạng thái</p>
            <div class="<%= ['relative h-4 w-4 shrink-0', (syncing_now ? nil : 'hidden')].compact.join(' ') %>" data-google-sheets-sync-status-target="progressWrapper">
              <svg class="h-4 w-4 -rotate-90" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="7" fill="none" stroke="currentColor" stroke-width="2" class="text-stone-200"></circle>
                <circle
                  cx="12"
                  cy="12"
                  r="7"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  class="text-primary-500 transition-all duration-300 ease-out"
                  style="stroke-dasharray: <%= progress_circumference %>; stroke-dashoffset: <%= progress_offset %>;"
                  data-google-sheets-sync-status-target="progressRing"
                ></circle>
              </svg>
            </div>
          </div>
          <div class="mt-2 flex items-center justify-between gap-3">
            <p class="text-lg font-semibold text-black" data-google-sheets-sync-status-target="statusLabel"><%= @setting.google_sheets_last_sync_status_label %></p>
            <span class="<%= ['text-xs font-semibold text-black/55', (syncing_now ? nil : 'hidden')].compact.join(' ') %>" data-google-sheets-sync-status-target="progressValue"><%= @setting.google_sheets_sync_progress.to_i %>%</span>
          </div>
        </div>

        <div class="rounded-[24px] border border-black/10 bg-stone-50 p-4">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-black/40">Lần sync gần nhất</p>
          <p class="mt-2 text-lg font-semibold text-black" data-google-sheets-sync-status-target="lastSyncedAt">
            <%= @setting.google_sheets_display_time(@setting.google_sheets_last_synced_at) || 'Chưa có' %>
          </p>
        </div>

        <div class="rounded-[24px] border border-black/10 bg-stone-50 p-4">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-black/40">Lần chạy kế tiếp</p>
          <p class="mt-2 text-lg font-semibold text-black" data-google-sheets-sync-status-target="nextSyncAt">
            <%= @setting.google_sheets_display_time(@setting.google_sheets_next_sync_at) || 'Chưa lên lịch' %>
          </p>
        </div>

        <div class="rounded-[24px] border border-black/10 bg-stone-50 p-4">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-black/40">Chu kỳ hiện tại</p>
          <p class="mt-2 text-lg font-semibold text-black"><%= @setting.google_sheets_interval_label %></p>
        </div>
      </div>

      <div class="<%= ['rounded-[24px] border border-rose-200 bg-rose-50 p-4', (@setting.google_sheets_last_sync_error.present? ? nil : 'hidden')].compact.join(' ') %>" data-google-sheets-sync-status-target="errorBox">
          <p class="text-sm font-semibold text-rose-700">Lỗi sync gần nhất</p>
          <p class="mt-2 text-sm leading-6 text-rose-700/85" data-google-sheets-sync-status-target="errorText"><%= @setting.google_sheets_last_sync_error %></p>
      </div>

      <div class="flex flex-wrap items-center justify-end gap-3">
        <div class="flex flex-wrap items-center gap-3">
          <%= render ButtonComponent.new(
            label: 'Lưu cấu hình',
            type: :submit,
            variant: :primary,
            icon: 'save'
          ) %>
        </div>
      </div>
    <% end %>

  </div>
</section>
