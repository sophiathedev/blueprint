<% from_modal = local_assigns.fetch(:from_modal, false) %>

<%= form_with model: [:admin, partner], class: 'space-y-4', data: { controller: 'modal-form', action: 'submit->modal-form#handleSubmit turbo:before-fetch-response->modal-form#beforeFetchResponse turbo:submit-end->modal-form#submitEnd' } do |form| %>
  <%= hidden_field_tag :from_modal, '1' if from_modal %>

  <% if from_modal %>
    <%= render InputFieldComponent.new(
      form: form,
      field: :name,
      label: 'Tên',
      placeholder: 'Nhập tên đối tác',
      autofocus: true,
      onkeydown: "if (event.key === 'Enter') { event.preventDefault(); this.form?.requestSubmit(); }",
      data: { autofocus_modal: true }
    ) %>
  <% else %>
    <div class="rounded-[28px] border border-black/10 bg-white p-5 md:p-6">
      <div class="mb-5">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-600">Thông tin đối tác</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-black">Cập nhật dữ liệu cơ bản</h2>
        <p class="mt-2 text-sm leading-6 text-black/55">
          Hiện tại đối tác gồm một trường thông tin là tên. Bạn có thể chỉnh sửa lại bất cứ lúc nào.
        </p>
      </div>

      <%= render InputFieldComponent.new(
        form: form,
        field: :name,
        label: 'Tên',
        placeholder: 'Nhập tên đối tác'
      ) %>
    </div>
  <% end %>

  <div class="flex items-center justify-end gap-2">
    <% if from_modal %>
      <button
        type="button"
        class="inline-flex items-center justify-center gap-2 rounded-2xl border border-stone-200 bg-stone-100 px-3 py-2 text-sm font-semibold text-black transition-colors hover:border-stone-300 hover:bg-stone-200"
        data-action="modal#close"
      >
        Hủy
      </button>
    <% end %>
    
    <%= render ButtonComponent.new(
      label: partner.persisted? ? 'Lưu thay đổi' : 'Tạo đối tác',
      type: :submit,
      variant: :primary,
      icon: partner.persisted? ? 'save' : 'plus'
    ) %>

    <% unless from_modal %>
      <%= render ButtonComponent.new(
        label: 'Quay lại danh sách',
        type: :navigate,
        href: back_path(admin_partners_path),
        icon: 'arrow-left'
      ) %>
    <% end %>
  </div>
<% end %>
