<% content_for :title, 'Blueprint | Sửa đối tác' %>

<section class="space-y-5">
  <div class="rounded-[28px] border border-black/10 bg-stone-50 p-5 md:p-6">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-600">Admin / Đối tác</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-black">Chỉnh sửa đối tác</h1>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-black/60">
      Cập nhật lại thông tin của đối tác <span class="font-semibold text-black"><%= @partner.name %></span>.
    </p>
  </div>

  <%= render 'form', partner: @partner %>
</section>
