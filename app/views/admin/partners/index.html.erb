<% content_for :title, 'Blueprint | Đối tác' %>

<section data-controller="search-form modal" data-modal-open-value="<%= @open_partner_modal.present? %>">
  <div class="rounded-[28px] border border-black/10 bg-white p-5 md:p-6">
    <div class="flex flex-col gap-4 border-b border-black/10 pb-5 md:flex-row md:items-end md:justify-between">
      <h1 class="text-3xl font-semibold tracking-tight text-black">Quản lý đối tác</h1>

      <div class="flex w-full flex-col gap-3 md:w-auto md:flex-row md:items-center">
        <div class="relative w-full md:w-[280px]">
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-black/35">
            <%= lucide_icon('search', class: 'h-4 w-4', "aria-hidden": true) %>
          </span>
          <input
            type="text"
            name="q"
            value="<%= @query %>"
            placeholder="Tìm theo tên đối tác"
            class="w-full rounded-2xl border border-stone-200 bg-stone-50 py-2 pl-10 pr-3 text-sm text-black outline-none transition focus:border-primary-400 focus:bg-white focus:ring-4 focus:ring-primary-100"
            data-search-form-target="input"
            data-action="input->search-form#submitWithDebounce"
          >
        </div>

        <button
          type="button"
          class="inline-flex items-center justify-center gap-2 rounded-2xl border border-primary-500 bg-primary-500 px-3 py-2 text-sm font-semibold text-white transition-colors hover:border-primary-600 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:ring-offset-2"
          data-action="click->modal#open"
        >
          <%= lucide_icon('plus', class: 'h-4 w-4 shrink-0', "aria-hidden": true) %>
          <span>Thêm đối tác</span>
        </button>
      </div>
    </div>

    <% if @partners.any? %>
      <div class="mt-5 overflow-visible" data-search-form-target="table">
        <div class="overflow-hidden rounded-t-[24px] border border-black/10 border-b-0">
          <div class="grid grid-cols-[56px_minmax(0,1fr)_44px] items-center gap-2 bg-stone-50 px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-black/45">
            <span class="text-center">STT</span>
            <span>Tên</span>
            <span class="text-right"></span>
          </div>
        </div>

        <div class="overflow-visible rounded-b-[24px] border border-black/10 bg-white">
          <% @partners.each_with_index do |partner, index| %>
            <div
              class="<%= [
                'grid grid-cols-[56px_minmax(0,1fr)_44px] items-center gap-2 px-3 py-2.5',
                index.zero? ? nil : 'border-t border-black/10'
              ].compact.join(' ') %>"
              data-search-form-target="row"
              data-search-name="<%= partner.name %>"
            >
              <div class="text-sm text-center font-medium text-black/55"><%= index + 1 %></div>

              <div class="flex min-w-0 items-center">
                <div id="partner-display-<%= partner.id %>" class="flex min-w-0 items-center gap-2">
                  <button
                    type="button"
                    class="flex min-w-0 items-center gap-2 text-left"
                    onclick="document.getElementById('partner-display-<%= partner.id %>')?.classList.add('hidden'); document.getElementById('partner-edit-<%= partner.id %>')?.classList.remove('hidden'); const input = document.getElementById('partner-input-<%= partner.id %>'); input?.focus(); input?.select();"
                  >
                    <span class="truncate text-sm font-semibold text-black"><%= partner.name %></span>
                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-stone-100 text-black/55 transition hover:bg-stone-200 hover:text-black">
                      <%= lucide_icon('pencil', class: 'h-3.5 w-3.5', "aria-hidden": true) %>
                    </span>
                  </button>
                </div>

                <div id="partner-edit-<%= partner.id %>" class="hidden w-full">
                  <%= form_with model: [:admin, partner], class: 'w-full' do |form| %>
                    <%= hidden_field_tag :from_inline, '1' %>
                    <%= form.text_field :name,
                      id: "partner-input-#{partner.id}",
                      value: partner.name,
                      class: 'w-full rounded-2xl border border-stone-200 bg-white px-3 py-2 text-sm font-medium text-black outline-none transition focus:border-primary-400 focus:ring-4 focus:ring-primary-100',
                      onblur: 'this.form.requestSubmit()',
                      onkeydown: "if (event.key === 'Enter') { event.preventDefault(); this.form.requestSubmit(); } if (event.key === 'Escape') { event.preventDefault(); this.value = this.defaultValue; this.form.closest(\"#partner-edit-#{partner.id}\")?.classList.add(\"hidden\"); document.getElementById(\"partner-display-#{partner.id}\")?.classList.remove(\"hidden\"); }"
                    %>
                  <% end %>
                </div>
              </div>

              <div class="flex items-center justify-end overflow-visible">
                <%= render DropdownComponent.new(
                  items: [
                    { label: 'Dịch vụ', href: '#', icon: 'briefcase-business' },
                    { label: 'Xóa đối tác', href: admin_partner_path(partner), method: :delete, icon: 'trash-2', tone: :danger, confirm_label: 'Xác nhận xóa?', confirm_icon: 'check' }
                  ],
                  direction: :bottom_right
                ) do |dropdown| %>
                  <% dropdown.with_trigger do %>
                    <button
                      type="button"
                      class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-black/55 ring-1 ring-black/10 transition hover:bg-stone-100 hover:text-black"
                      aria-label="Mở thao tác đối tác"
                    >
                      <%= lucide_icon('ellipsis', class: 'h-4 w-4', "aria-hidden": true) %>
                    </button>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="mt-5 hidden rounded-[24px] border border-dashed border-black/15 bg-stone-50 px-5 py-10 text-center" data-search-form-target="noResults">
        <h2 class="text-lg font-semibold text-black">Không tìm thấy đối tác phù hợp</h2>
        <p class="mt-2 text-sm leading-6 text-black/55">
          Thử nhập lại tên đối tác với từ khóa khác.
        </p>
      </div>
    <% else %>
      <div class="mt-5 rounded-[24px] border border-dashed border-black/15 bg-stone-50 px-5 py-10 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-primary-600 shadow-sm ring-1 ring-black/5">
          <%= lucide_icon('handshake', class: 'h-6 w-6', "aria-hidden": true) %>
        </div>
        <h2 class="mt-4 text-xl font-semibold text-black">Chưa có đối tác nào</h2>
        <p class="mt-2 text-sm leading-6 text-black/55">
          Tạo đối tác đầu tiên để bắt đầu quản lý danh sách ngay trong khu vực admin.
        </p>
        <div class="mt-5">
          <button
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-2xl border border-primary-500 bg-primary-500 px-3 py-2 text-sm font-semibold text-white transition-colors hover:border-primary-600 hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:ring-offset-2"
            data-action="click->modal#open"
          >
            <%= lucide_icon('plus', class: 'h-4 w-4 shrink-0', "aria-hidden": true) %>
            <span>Tạo đối tác đầu tiên</span>
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <%= render ModalComponent.new(title: 'Tạo đối tác mới', open: @open_partner_modal.present?) do |modal| %>
    <% modal.with_body do %>
      <%= render 'form', partner: @partner, from_modal: true %>
    <% end %>
  <% end %>
</section>
