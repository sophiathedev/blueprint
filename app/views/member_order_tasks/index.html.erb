<% content_for :title, 'Blueprint | Quản lý Task' %>

<section class="space-y-5" data-controller="search-form" data-search-form-mode-value="server" data-search-form-delay-value="500">
  <section class="rounded-[32px] border border-black/10 bg-white p-5 shadow-sm md:p-6">
    <div class="border-b border-black/10 pb-5">
      <h1 class="text-3xl font-semibold tracking-tight text-black">Quản lý Task</h1>
      <p class="mt-2 text-sm text-black/55">
        Theo dõi và cập nhật các task trong order đang được giao cho bạn.
      </p>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      <%= link_to member_order_tasks_path(filter: :all, q: @query.presence), class: [
        'block rounded-[22px] border p-4 transition hover:-translate-y-0.5 hover:shadow-sm',
        (@task_filter == 'all' ? 'border-primary-300 bg-primary-50 ring-2 ring-primary-100' : 'border-black/10 bg-stone-50 hover:border-black/15')
      ].join(' ') do %>
        <p class="<%= ['text-[11px] font-semibold uppercase tracking-[0.18em]', (@task_filter == 'all' ? 'text-primary-600' : 'text-black/40')].join(' ') %>">Tổng task</p>
        <p class="<%= ['mt-2 text-3xl font-semibold', (@task_filter == 'all' ? 'text-primary-700' : 'text-black')].join(' ') %>"><%= @total_order_tasks_count %></p>
        <p class="<%= ['mt-1 text-sm', (@task_filter == 'all' ? 'text-primary-700/80' : 'text-black/55')].join(' ') %>">task đang thuộc order của bạn</p>
      <% end %>

      <%= link_to member_order_tasks_path(filter: :pending, q: @query.presence), class: [
        'block rounded-[22px] border p-4 transition hover:-translate-y-0.5 hover:shadow-sm',
        (@task_filter == 'pending' ? 'border-amber-300 bg-amber-50 ring-2 ring-amber-100' : 'border-black/10 bg-stone-50 hover:border-black/15')
      ].join(' ') do %>
        <p class="<%= ['text-[11px] font-semibold uppercase tracking-[0.18em]', (@task_filter == 'pending' ? 'text-amber-600' : 'text-black/40')].join(' ') %>">Cần xử lý</p>
        <p class="<%= ['mt-2 text-3xl font-semibold', (@task_filter == 'pending' ? 'text-amber-700' : 'text-black')].join(' ') %>"><%= @pending_order_tasks_count %></p>
        <p class="<%= ['mt-1 text-sm', (@task_filter == 'pending' ? 'text-amber-700/80' : 'text-black/55')].join(' ') %>">task chưa hoàn thành</p>
      <% end %>

      <%= link_to member_order_tasks_path(filter: :overdue, q: @query.presence), class: [
        'block rounded-[22px] border p-4 transition hover:-translate-y-0.5 hover:shadow-sm',
        (@task_filter == 'overdue' ? 'border-rose-300 bg-rose-100 ring-2 ring-rose-100' : 'border-rose-200 bg-rose-50 hover:border-rose-300')
      ].join(' ') do %>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-rose-500">Trễ hạn</p>
        <p class="mt-2 text-3xl font-semibold text-rose-700"><%= @overdue_order_tasks_count %></p>
        <p class="mt-1 text-sm text-rose-700/75">task đã vượt deadline</p>
      <% end %>

      <%= link_to member_order_tasks_path(filter: :completed, q: @query.presence), class: [
        'block rounded-[22px] border p-4 transition hover:-translate-y-0.5 hover:shadow-sm',
        (@task_filter == 'completed' ? 'border-emerald-300 bg-emerald-100 ring-2 ring-emerald-100' : 'border-emerald-200 bg-emerald-50 hover:border-emerald-300')
      ].join(' ') do %>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-emerald-500">Hoàn thành</p>
        <p class="mt-2 text-3xl font-semibold text-emerald-700"><%= @completed_order_tasks_count %></p>
        <p class="mt-1 text-sm text-emerald-700/75">task đã xử lý xong</p>
      <% end %>
    </div>
  </section>

  <section class="rounded-[32px] border border-black/10 bg-white p-4 shadow-sm md:p-5">
    <div class="flex flex-col gap-2 border-b border-black/10 pb-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-black">Danh sách task trong order</h2>
        <p class="mt-1 text-sm text-black/55">
          Ưu tiên hiển thị các task chưa hoàn thành và các task đã trễ hạn.
        </p>
      </div>

      <div class="flex w-full flex-col gap-3 md:w-auto md:flex-row md:items-center">
        <div class="relative w-full md:w-[320px]" data-controller="clearable-input">
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-black/35">
            <%= lucide_icon('search', class: 'h-4 w-4', "aria-hidden": true) %>
          </span>
          <input
            type="text"
            name="q"
            value="<%= @query %>"
            placeholder="Tìm theo tên task hoặc đối tác"
            class="w-full rounded-2xl border border-stone-200 bg-stone-50 py-2 pl-10 pr-10 text-sm text-black outline-none transition focus:border-primary-400 focus:bg-white focus:ring-4 focus:ring-primary-100"
            data-search-form-target="input"
            data-clearable-input-target="input"
            data-action="input->search-form#submitWithDebounce input->clearable-input#sync"
          >
          <button
            type="button"
            class="absolute inset-y-0 right-0 hidden items-center pr-3 text-black/35 transition hover:text-black"
            data-clearable-input-target="clear"
            data-action="click->clearable-input#clear click->search-form#submitWithDebounce"
            aria-label="Xóa nội dung"
          >
            <%= lucide_icon('x', class: 'h-4 w-4', "aria-hidden": true) %>
          </button>
        </div>

        <% if @task_filter != 'all' || @query.present? %>
          <%= link_to member_order_tasks_path,
            class: 'inline-flex items-center gap-2 rounded-2xl border border-stone-200 bg-stone-100 px-3 py-2 text-sm font-semibold text-black transition-colors hover:border-stone-300 hover:bg-stone-200' do %>
            <%= lucide_icon('x', class: 'h-4 w-4', "aria-hidden": true) %>
            Bỏ lọc
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @order_tasks.any? %>
      <div class="mt-4 overflow-hidden rounded-[24px] border border-black/10">
        <div class="hidden md:block">
          <table class="min-w-full table-fixed border-collapse bg-white">
            <colgroup>
              <col class="w-[36%]">
              <col class="w-[24%]">
              <col class="w-[22%]">
              <col class="w-[18%]">
            </colgroup>
            <thead>
              <tr class="bg-stone-50 text-[11px] font-semibold uppercase tracking-[0.18em] text-black/40">
                <th class="px-5 py-3 text-left">Task</th>
                <th class="px-5 py-3 text-left">Đối tác</th>
                <th class="px-5 py-3 text-left">Deadline</th>
                <th class="px-5 py-3 text-left">Trạng thái</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black/8">
              <% @order_tasks.each do |order_task| %>
                <% order_service = order_task.order_service %>
                <% service = order_task.task.service %>
                <% partner = service.partner %>
                <tr
                  class="<%= ['group h-24 cursor-pointer transition hover:bg-stone-100', (order_task.is_overdue? && !order_task.is_completed? ? 'bg-rose-50/35 hover:bg-rose-100/70' : nil)].compact.join(' ') %>"
                  onclick="window.location='<%= admin_order_service_path(order_service, source: :member_tasks) %>'"
                >
                  <td class="cursor-pointer px-5 py-4 align-middle">
                    <div class="flex h-full items-center gap-3">
                      <%= form_with model: [:admin, order_service, order_task], method: :patch, class: 'mt-0.5 shrink-0', html: { onclick: 'event.stopPropagation()' } do |form| %>
                        <%= hidden_field_tag :source, 'member_tasks' %>
                        <%= render CheckboxComponent.new(
                          form:,
                          attribute: :is_completed,
                          checked: order_task.is_completed?,
                          disabled: order_task.is_completed?,
                          aria: { label: "Đánh dấu hoàn thành cho task #{order_task.task.name}" },
                          onchange: 'this.form.requestSubmit()'
                        ) %>
                      <% end %>

                      <div class="min-w-0">
                        <div class="flex flex-wrap items-center gap-2">
                          <p class="truncate text-sm font-semibold text-black"><%= order_task.task.name %></p>
                          <% if order_task.is_overdue? %>
                            <span class="inline-flex items-center gap-2 rounded-full border border-rose-200 bg-rose-50 px-2.5 py-1 text-[11px] font-semibold text-rose-700">
                              <span class="h-2 w-2 rounded-full bg-rose-500"></span>
                              <%= dashboard_order_task_overdue_badge_text(order_task) %>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td class="cursor-pointer px-5 py-4 align-middle">
                    <div class="flex h-full items-center">
                      <p class="truncate text-sm font-medium text-black/75"><%= partner.name %></p>
                    </div>
                  </td>
                  <td class="cursor-pointer px-5 py-4 align-middle">
                    <div class="flex h-full flex-col justify-center">
                      <p class="text-sm font-medium text-black/75">Deadline <%= order_service.completed_at.strftime('%H:%M %d/%m/%Y') %></p>
                      <% if order_task.mark_completed_at.present? %>
                        <p class="mt-1 text-xs text-black/45">Hoàn thành <%= order_task.mark_completed_at.strftime('%H:%M %d/%m/%Y') %></p>
                      <% end %>
                    </div>
                  </td>
                  <td class="cursor-pointer px-5 py-4 align-middle">
                    <div class="flex h-full items-center">
                      <div class="flex flex-wrap items-center gap-2">
                        <% if order_task.is_completed? %>
                          <span class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-[11px] font-semibold text-emerald-700">
                            <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                            Hoàn thành
                          </span>
                        <% else %>
                          <span class="inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-[11px] font-semibold text-amber-700">
                            <span class="h-2 w-2 rounded-full bg-amber-500"></span>
                            Chưa hoàn thành
                          </span>
                        <% end %>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="divide-y divide-black/8 bg-white md:hidden">
            <% @order_tasks.each do |order_task| %>
              <% order_service = order_task.order_service %>
              <% service = order_task.task.service %>
              <% partner = service.partner %>
            <article
              class="space-y-3 cursor-pointer p-4 transition hover:bg-stone-100"
              onclick="window.location='<%= admin_order_service_path(order_service, source: :member_tasks) %>'"
            >
              <div class="flex items-start gap-3">
                <%= form_with model: [:admin, order_service, order_task], method: :patch, class: 'mt-0.5 shrink-0', html: { onclick: 'event.stopPropagation()' } do |form| %>
                  <%= hidden_field_tag :source, 'member_tasks' %>
                  <%= render CheckboxComponent.new(
                    form:,
                    attribute: :is_completed,
                    checked: order_task.is_completed?,
                    disabled: order_task.is_completed?,
                    aria: { label: "Đánh dấu hoàn thành cho task #{order_task.task.name}" },
                    onchange: 'this.form.requestSubmit()'
                  ) %>
                <% end %>

                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="truncate text-base font-semibold text-black"><%= order_task.task.name %></h3>
                    <% if order_task.is_overdue? %>
                      <span class="inline-flex items-center gap-2 rounded-full border border-rose-200 bg-rose-50 px-2.5 py-1 text-[11px] font-semibold text-rose-700">
                        <span class="h-2 w-2 rounded-full bg-rose-500"></span>
                        <%= dashboard_order_task_overdue_badge_text(order_task) %>
                      </span>
                    <% end %>
                  </div>
                  <p class="mt-1 text-sm text-black/55"><%= partner.name %></p>
                </div>
              </div>

              <div class="flex flex-wrap items-center gap-2">
                <% if order_task.is_completed? %>
                  <span class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-[11px] font-semibold text-emerald-700">
                    <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                    Hoàn thành
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-[11px] font-semibold text-amber-700">
                    <span class="h-2 w-2 rounded-full bg-amber-500"></span>
                    Chưa hoàn thành
                  </span>
                <% end %>

              </div>

              <div class="grid gap-2 rounded-[22px] border border-black/10 bg-stone-50 p-3">
                <p class="text-sm text-black/70"><span class="font-semibold text-black">Deadline:</span> <%= order_service.completed_at.strftime('%H:%M %d/%m/%Y') %></p>
                <% if order_task.mark_completed_at.present? %>
                  <p class="text-sm text-black/70"><span class="font-semibold text-black">Hoàn thành:</span> <%= order_task.mark_completed_at.strftime('%H:%M %d/%m/%Y') %></p>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="mt-4 rounded-[24px] border border-dashed border-black/10 bg-stone-50 p-5">
        <p class="text-sm font-semibold text-black">Chưa có task nào được giao</p>
        <p class="mt-2 text-sm leading-6 text-black/60">
          Khi một task trong order được assign cho bạn, nó sẽ xuất hiện ở đây để bạn tiện theo dõi và cập nhật.
        </p>
      </div>
    <% end %>
  </section>
</section>
