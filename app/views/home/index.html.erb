<%
  primary_colors = {
    "50" => "#FDF2F2",
    "100" => "#FBE6E6",
    "200" => "#F5C7C7",
    "300" => "#EE9E9F",
    "400" => "#E25A5B",
    "500" => "#D30102",
    "600" => "#BA0102",
    "700" => "#A00102",
    "800" => "#830101",
    "900" => "#650001",
    "950" => "#3F0001"
  }

  core_colors = {
    "Primary" => "#D30102",
    "White" => "#FFFFFF",
    "Black" => "#000000"
  }
%>

<main class="min-h-screen bg-white px-6 py-12 text-black">
  <div class="mx-auto flex max-w-6xl flex-col gap-10">
    <section class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary-500">Blueprint Core Colors</p>
      <h1 class="text-4xl font-bold tracking-tight">Palette từ `primary`, `white`, và `black`</h1>
      <p class="max-w-3xl text-base leading-7 text-black/70">
        `primary` được cố định tại <span class="font-semibold text-primary-500">#D30102</span>, sau đó mở rộng thành
        thang màu để dùng cho background, border, hover, active, và text emphasis.
      </p>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
      <% core_colors.each do |name, hex| %>
        <article class="overflow-hidden rounded-3xl border border-black/10 bg-white shadow-sm">
          <div class="h-32" style="background-color: <%= hex %>;"></div>
          <div class="space-y-1 p-5">
            <p class="text-sm font-medium uppercase tracking-[0.18em] text-black/50"><%= name %></p>
            <p class="text-2xl font-semibold"><%= hex %></p>
          </div>
        </article>
      <% end %>
    </section>

    <section class="space-y-4">
      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight">Primary Scale</h2>
          <p class="text-sm text-black/60">Dùng trực tiếp với class như `bg-primary-500`, `text-primary-700`, `border-primary-200`.</p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        <% primary_colors.each do |step, hex| %>
          <article class="overflow-hidden rounded-3xl border border-black/10 bg-white shadow-sm">
            <div class="h-28" style="background-color: <%= hex %>;"></div>
            <div class="flex items-center justify-between gap-3 p-5">
              <div>
                <p class="text-sm font-medium uppercase tracking-[0.18em] text-black/50">Primary <%= step %></p>
                <p class="text-xl font-semibold"><%= hex %></p>
              </div>
              <div class="rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">
                <%= step == "500" ? "Base" : "Scale" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</main>
