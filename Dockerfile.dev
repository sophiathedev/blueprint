# syntax=docker/dockerfile:1
# check=error=true

# This Dockerfile is designed for development and mirrors the production image
# as closely as possible while keeping the environment convenient for local work.

# Make sure RUBY_VERSION matches the Ruby version in .ruby-version
ARG RUBY_VERSION=4.0.1
FROM docker.io/library/ruby:$RUBY_VERSION-slim AS base

# Rails app lives here
WORKDIR /rails

# Install base packages
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y curl libjemalloc2 libvips postgresql-client && \
    ln -s /usr/lib/$(uname -m)-linux-gnu/libjemalloc.so.2 /usr/local/lib/libjemalloc.so && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

# Set development environment variables and enable jemalloc.
ENV RAILS_ENV="development" \
    BUNDLE_DEPLOYMENT="0" \
    BUNDLE_PATH="/usr/local/bundle" \
    BUNDLE_WITHOUT="" \
    LD_PRELOAD="/usr/local/lib/libjemalloc.so"

# Build stage shared with the final dev image so native gem dependencies stay available.
FROM base AS build

# Install packages needed to build gems
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y build-essential git libpq-dev libyaml-dev pkg-config && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

# Install application gems, including development dependencies
COPY vendor/* ./vendor/
COPY Gemfile Gemfile.lock ./

RUN bundle install -j12

# Copy application code
COPY . .

# Final stage for dev app image
FROM build

# Entrypoint prepares the environment when needed.
ENTRYPOINT ["/rails/bin/docker-entrypoint"]

EXPOSE 3000
CMD ["bin/dev"]
